@{
    ViewData["Title"] = "Магазин";
}

<h1>@ViewBag.StoreName</h1>
<p>Добро пожаловать в наш магазин!</p>
<div class="store-info">
    <h3>Информация о магазине:</h3>
    <ul>
        <li><strong>Название:</strong> @ViewBag.StoreName</li>
        <li><strong>Количество товаров:</strong> @ViewData["ProductsCount"]</li>
        <li><strong>Дата:</strong> @DateTime.Now.ToString("dd.MM.yyyy")</li>
    </ul>
</div>

<hr />
<h3>Навигация по магазину:</h3>
<div class="navigation-links">
<div style="display: flex; gap: 10px; margin: 20px 0;">
    <a href="/store/category/electronics" style="padding: 10px; background-color: #007bff; color: white; text-decoration: none; border-radius: 5px;">Электроника</a>
    <a href="/store/category/books" style="padding: 10px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 5px;">Книги</a>
    <a href="/shop/category/clothing" style="padding: 10px; background-color: #28a745; color: white; text-decoration: none; border-radius: 5px;">Одежда</a>
    <a href="/store/product/1/details" style="padding: 10px; background-color: #17a2b8; color: white; text-decoration: none; border-radius: 5px;">Товар #1</a>
    <a href="/store/product/42/details" style="padding: 10px; background-color: #ffc107; color: black; text-decoration: none; border-radius: 5px;">Товар #42</a>
</div>

<hr />
<h3>Тестирование разных URL:</h3>
<div class="test-urls">
    </ul>
    <li><code>/store</code>-главная страница магазина</li>
    <li><code>/shop</code>-альтернативный URl (тот же Index</li>
    <li><code>/store/category/electronics</code>-категория электроники</li>
    <li><code>/shop/category/books</code>- категрия книг через shop</li>
    <li><code>/store/product/42/details</code>-детали товара 42</li>
</<ul>
</<div>

<style>
    .store-info{
        backhround-color: #f8f9fa
        padding: 20px; 
        border-radius:5px; 
        margin:20px 0; 
    }
    .navigation-links{
        display:flex; 
        flex-wrap; wrap; 
        gap: 10px; 
        margin: 20px 0;
    }
    .test-urls{
        background-color: #e9ecef; 
        padding: 15px; 
        border-radius: 5px; 
        font-family: monospace; 
    }
    .test-urls ul{
        list-style-type:none; 
        padding-left:0; 
    }
    .test-irls li {
        margin-bottom: 8px; 
        padding: 5px; 
        background-color: white;
        border-radius: 3px;
    }
</style>