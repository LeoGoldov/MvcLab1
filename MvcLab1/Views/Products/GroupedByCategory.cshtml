@using System.Linq
@model IEnumerable<MvcLab1.Models.Product>

@{
    ViewData["Title"] = "Товары по категориям";
    var grouped = Model.GroupBy(p => p.Category).OrderBy(g => g.Key);
}

<h1>Товары по категориям</h1>

@if (!Model.Any())
{
        <div class="alert alert-warning">
            В базе данных нет товаров. Добавьте хотя бы один товар через 
            <a asp-action="Create">форму создания</a>.
        </div>
}
else
{
        <div class="accordion" id="categoriesAccordion">
        @{
            int index = 0;
        }
        @foreach (var group in grouped)
        {
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button @(index != 0 ? "collapsed" : "")" 
                                    type="button" data-bs-toggle="collapse" 
                                    data-bs-target="#collapse@(index)" aria-expanded="@(index == 0 ? "true" : "false")">
                        @group.Key 
                                <span class="badge bg-secondary ms-2">@group.Count() товаров</span>
                            </button>
                        </h2>
                        <div id="collapse@(index)" class="accordion-collapse collapse @(index == 0 ? "show" : "")" 
                             data-bs-parent="#categoriesAccordion">
                            <div class="accordion-body">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Название</th>
                                            <th>Цена</th>
                                            <th>В наличии</th>
                                            <th>Дата добавления</th>
                                            <th>Действия</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                @foreach (var product in group)
                                {
                                                <tr>
                                                    <td>@product.Name</td>
                                                    <td>@product.Price.ToString("C")</td>
                                                    <td>@(product.InStock ? "✅ Да" : "❌ Нет")</td>
                                                    <td>@product.CreatedDate.ToShortDateString()</td>
                                                    <td>
                                                        <a asp-action="Details" asp-route-id="@product.Id">Детали</a>
                                                    </td>
                                                </tr>
                                }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
            index++;
        }
        </div>
}