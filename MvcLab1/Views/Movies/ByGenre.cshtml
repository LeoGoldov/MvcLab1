@model IEnumerable<MvcLab1.Models.Movie>

@{
    ViewData["Title"] = $"Фильмы в жанре: {ViewBag.Genre}";
}

<h1>Фильмы в жанре: <span class="text-primary">@ViewBag.Genre</span></h1>

@if (!Model.Any())
{
        <div class="alert alert-info">
            <p>Фильмы в жанре "@ViewBag.Genre" не найдены.</p>
        </div>
}
else
{
        <p>Найдено фильмов: <strong>@Model.Count()</strong></p>

        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Название</th>
                    <th>Режиссер</th>
                    <th>Год</th>
                    <th>Длительность</th>
                    <th>Рейтинг</th>
                    <th>Доступность</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Director</td>
                            <td>@item.Year</td>
                            <td>@item.GetHours()</td>
                            <td>⭐ @item.Rating.ToString("F1")</td>
                            <td>
                        @if (item.IsAvailable)
                        {
                                        <span class="badge bg-success">Доступен</span>
                        }
                        else
                        {
                                        <span class="badge bg-danger">Недоступен</span>
                        }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                            </td>
                        </tr>
            }
            </tbody>
        </table>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Назад ко всем фильмам</a>
</div>