@model IEnumerable<MvcLab1.Models.Movie>

@{
    ViewData["Title"] = "Коллекция фильмов";
}

<h1>Коллекция фильмов</h1>

@if (TempData["SuccessMessage"] != null)
{
        <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Добавить фильм</a>
    <a asp-action="HighRated" class="btn btn-warning">Высокий рейтинг (8+)</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Id)</th>
            <th>@Html.DisplayNameFor(model => model.Title)</th>
            <th>@Html.DisplayNameFor(model => model.Director)</th>
            <th>@Html.DisplayNameFor(model => model.Year)</th>
            <th>@Html.DisplayNameFor(model => model.Genre)</th>
            <th>@Html.DisplayNameFor(model => model.Duration)</th>
            <th>@Html.DisplayNameFor(model => model.Rating)</th>
            <th>@Html.DisplayNameFor(model => model.IsAvailable)</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Title</td>
                    <td>@item.Director</td>
                    <td>@item.Year</td>
                    <td>@item.Genre</td>
                    <td>@item.GetHours()</td>
                    <td>
                    @if (item.Rating >= 8)
                    {
                                <span class="badge bg-success">⭐ @item.Rating.ToString("F1")</span>
                    }
                    else if (item.Rating >= 6)
                    {
                                <span class="badge bg-info">@item.Rating.ToString("F1")</span>
                    }
                    else
                    {
                                <span class="badge bg-secondary">@item.Rating.ToString("F1")</span>
                    }
                    </td>
                    <td>
                    @if (item.IsAvailable)
                    {
                                <span class="badge bg-success">Доступен</span>
                    }
                    else
                    {
                                <span class="badge bg-danger">Недоступен</span>
                    }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
                    </td>
                </tr>
        }
    </tbody>
</table>

<div class="mt-3">
    <h5>Фильтры по жанрам:</h5>
    @{
        var genres = Model.Select(m => m.Genre).Distinct();
        foreach (var genre in genres)
        {
                    <a asp-action="ByGenre" asp-route-genre="@genre" class="btn btn-sm btn-outline-secondary me-2">@genre</a>
        }
    }
</div>