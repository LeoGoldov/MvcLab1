@model MvcLab1.Models.Movie

@{
    ViewData["Title"] = $"Детали фильма: {Model.Title}";
}

<h1>Детали фильма</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Id)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Id)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Title)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Director)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Director)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Year)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Year)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Genre)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.Genre)
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Duration)
        </dt>
        <dd class="col-sm-9">
            @Model.GetHours()
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Rating)
        </dt>
        <dd class="col-sm-9">
            @if (Model.Rating >= 8)
            {
                    <span class="badge bg-success fs-6">⭐ @Model.Rating.ToString("F1") / 10</span>
            }
            else if (Model.Rating >= 6)
            {
                    <span class="badge bg-info fs-6">@Model.Rating.ToString("F1") / 10</span>
            }
            else
            {
                    <span class="badge bg-secondary fs-6">@Model.Rating.ToString("F1") / 10</span>
            }
        </dd>

        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.IsAvailable)
        </dt>
        <dd class="col-sm-9">
            @if (Model.IsAvailable)
            {
                    <span class="badge bg-success">✓ Доступен для просмотра</span>
            }
            else
            {
                    <span class="badge bg-danger">✗ Недоступен</span>
            }
        </dd>
    </dl>
</div>

<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <h5>Дополнительная информация</h5>
            </div>
            <div class="card-body">
                <p><strong>Возраст фильма:</strong> @(DateTime.Now.Year - Model.Year) лет</p>
                <p><strong>Рекомендация:</strong>
                    @if (Model.Rating >= 8)
                    {
                            <span class="text-success">Обязателен к просмотру! 🌟🌟🌟</span>
                    }
                    else if (Model.Rating >= 6)
                    {
                            <span class="text-info">Хороший фильм для просмотра 👍</span>
                    }
                    else
                    {
                            <span class="text-secondary">На любителя 🎬</span>
                    }
                </p>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редактировать</a>
    <a asp-action="Index" class="btn btn-secondary">Назад к списку</a>
</div>